  13   1          {
  14   2              TMOD &= 0xF0;    
  15   2              TMOD |= 0x01;    
  16   2              TH0 = 0xFC;     
  17   2              TL0 = 0x67; 
  18   2              TF0 = 0;         
  19   2              TR0 = 1;        
  20   2              
  21   2              while(TF0 == 0); 
  22   2              
  23   2              TR0 = 0;        
  24   2              TF0 = 0;        
  25   2          }
  26   1      }

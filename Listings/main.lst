 197          void delay(long time) // delay timer
 198          {               
 199   1        while(time--)
 200   1        {
 201   2          TMOD=0x01;// che do 16 bit khong tu nap lai
 202   2          TH0=0xFC;TL0=0x67; // 6*( 65536 - FC67+1)*(1/12000)=1000us =1ms
